{
  "mcpServers": {
    "media-forge": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/mcp/server.js"],
      "env": {
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "GOOGLE_PROJECT_ID": "${GOOGLE_PROJECT_ID}",
        "GOOGLE_LOCATION": "${GOOGLE_LOCATION}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "MEDIA_FORGE_PROJECT_DIR": "${CLAUDE_PROJECT_DIR}/.media-forge",
        "MEDIA_FORGE_OCR": "${MEDIA_FORGE_OCR}",
        "MEDIA_FORGE_REVIEW_THRESHOLD": "${MEDIA_FORGE_REVIEW_THRESHOLD}",
        "MEDIA_FORGE_MAX_FIX_ATTEMPTS": "${MEDIA_FORGE_MAX_FIX_ATTEMPTS}",
        "MINIO_ENDPOINT": "${MINIO_ENDPOINT}",
        "MINIO_REGION": "${MINIO_REGION}",
        "MINIO_BUCKET": "${MINIO_BUCKET}",
        "MINIO_ACCESS_KEY": "${MINIO_ACCESS_KEY}",
        "MINIO_SECRET_KEY": "${MINIO_SECRET_KEY}",
        "MINIO_USE_SSL": "${MINIO_USE_SSL}",
        "MEDIA_FORGE_WEBHOOK_PORT": "${MEDIA_FORGE_WEBHOOK_PORT}",
        "MEDIA_FORGE_WEBHOOK_SECRET": "${MEDIA_FORGE_WEBHOOK_SECRET}",
        "HF_API_KEY": "${HF_API_KEY}",
        "HF_API_SECRET": "${HF_API_SECRET}",
        "KLING_ACCESS_KEY": "${KLING_ACCESS_KEY}",
        "KLING_SECRET_KEY": "${KLING_SECRET_KEY}",
        "KLING_WATERMARK_DEFAULT": "${KLING_WATERMARK_DEFAULT:-false}",
        "KLING_JWT_CACHE_TTL_SEC": "${KLING_JWT_CACHE_TTL_SEC:-1500}",
        "MEDIA_FORGE_WEBHOOK_PUBLIC_URL": "${MEDIA_FORGE_WEBHOOK_PUBLIC_URL}",
        "FAL_KEY": "${FAL_KEY}",
        "BYTEPLUS_ARK_API_KEY": "${BYTEPLUS_ARK_API_KEY}",
        "MEDIA_FORGE_SEEDANCE_ENABLED": "${MEDIA_FORGE_SEEDANCE_ENABLED:-true}"
      }
    }
  }
}
