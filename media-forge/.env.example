# Auth
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Workspace
MEDIA_FORGE_OUTPUT_DIR=./outputs
MEDIA_FORGE_PROJECT_DIR=./.media-forge

# Behavior
MEDIA_FORGE_LOG_LEVEL=info
MEDIA_FORGE_LOG_FORMAT=json
MEDIA_FORGE_DRY_RUN=false
MEDIA_FORGE_POLL_INTERVAL_MS=10000
MEDIA_FORGE_POLL_MAX_ATTEMPTS=90
MEDIA_FORGE_RUN_LIVE_TESTS=false
MEDIA_FORGE_RUN_EVALS=false

# Cost guard (C4 fix: retry budget visible)
MEDIA_FORGE_DAILY_CAP_USD=25
MEDIA_FORGE_CONFIRM_THRESHOLD_USD=0.50
MEDIA_FORGE_BLOCK_THRESHOLD_USD=2.00
MEDIA_FORGE_RETRY_BUDGET_MULTIPLIER=3
MEDIA_FORGE_SHOW_RETRY_BUDGET=true

# Review
MEDIA_FORGE_OCR=cloud-vision
MEDIA_FORGE_OCR_GOOGLE_VISION_KEY=
MEDIA_FORGE_REVIEW_THRESHOLD=7.5
MEDIA_FORGE_MAX_FIX_ATTEMPTS=3
MEDIA_FORGE_SKIP_OCR_WHEN_NO_TEXT_INTENT=true

# Region
MEDIA_FORGE_REGION=
