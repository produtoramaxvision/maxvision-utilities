# Auth
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Workspace
MEDIA_FORGE_OUTPUT_DIR=./outputs
MEDIA_FORGE_PROJECT_DIR=./.media-forge

# Behavior
MEDIA_FORGE_LOG_LEVEL=info
MEDIA_FORGE_LOG_FORMAT=json
MEDIA_FORGE_DRY_RUN=false
MEDIA_FORGE_POLL_INTERVAL_MS=10000
MEDIA_FORGE_POLL_MAX_ATTEMPTS=90
MEDIA_FORGE_RUN_LIVE_TESTS=false
MEDIA_FORGE_RUN_EVALS=false

# Cost guard (C4 fix: retry budget visible)
MEDIA_FORGE_DAILY_CAP_USD=25
MEDIA_FORGE_CONFIRM_THRESHOLD_USD=0.50
MEDIA_FORGE_BLOCK_THRESHOLD_USD=2.00
MEDIA_FORGE_RETRY_BUDGET_MULTIPLIER=3
MEDIA_FORGE_SHOW_RETRY_BUDGET=true

# Review
MEDIA_FORGE_OCR=cloud-vision
MEDIA_FORGE_OCR_GOOGLE_VISION_KEY=
MEDIA_FORGE_REVIEW_THRESHOLD=7.5
MEDIA_FORGE_MAX_FIX_ATTEMPTS=3
MEDIA_FORGE_SKIP_OCR_WHEN_NO_TEXT_INTENT=true

# Region
MEDIA_FORGE_REGION=

# ---------------------------------------------------------------------------
# MinIO refs bucket (Phase 1+)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=https://s3.meuagente.api.br
MINIO_REGION=us-east-1
MINIO_BUCKET=media-forge-refs
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_USE_SSL=true

# ---------------------------------------------------------------------------
# Semantic search (Phase 2 only)
# ---------------------------------------------------------------------------
VOYAGE_API_KEY=
PGVECTOR_URL=postgresql://user:pass@host:5432/dbname

# ---------------------------------------------------------------------------
# Refs runtime toggles
# ---------------------------------------------------------------------------
MEDIA_FORGE_REFS_ENABLED=true
MEDIA_FORGE_REF_MATCH_ENABLED=false
MEDIA_FORGE_REF_MATCH_THRESHOLD=0.65

# ---------------------------------------------------------------------------
# Marengo 3.0 via AWS Bedrock (Phase 2.8 alternative embedding backend)
# ---------------------------------------------------------------------------
MEDIA_FORGE_EMBED_BACKEND=voyage   # or "marengo" to swap
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MARENGO_MODEL_ID=twelvelabs.marengo-embed-3-0-v1:0

# ---------------------------------------------------------------------------
# Seedance 2.0 — ByteDance video model via fal.ai + BytePlus ARK fallback (P16)
# ---------------------------------------------------------------------------
# Primary: fal.ai USD billing, no China KYC. Get key at https://fal.ai/dashboard/keys
FAL_KEY=
# Fallback: BytePlus ModelArk REST, activates when fal.ai returns 5xx.
# Get key at https://console.byteplus.com/auth/api-key
BYTEPLUS_ARK_API_KEY=
# Emergency kill switch — set false to disable all Seedance tools without code changes.
MEDIA_FORGE_SEEDANCE_ENABLED=true
