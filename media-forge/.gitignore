# Build outputs
node_modules/
dist/
coverage/
*.tsbuildinfo

# Runtime / workspace
.media-forge/
outputs/

# Generated prompt index (rebuilt by scripts/build-prompt-index.ts)
prompts/_index.json

# Env (NEVER commit real secrets)
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
*.log
.idea/
.vscode/

# Negations — these MUST be tracked despite global gitignore rules
!pnpm-lock.yaml
!bin/
!src/core/
!src/cli/
!tests/
!tests/**/core/
!tests/**/core/**

# Stray planning-state directory — debts/specs/plans live in the maxvision-audiovisual repo
.maxvision/

# Eval run artifacts (generated on test execution, never commit)
tests/evals/results.jsonl
