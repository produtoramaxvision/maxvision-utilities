strict-peer-dependencies=false
auto-install-peers=true
shamefully-hoist=false
package-manager-strict=true
# embedded-postgres ships native initdb/postgres .exe that resolve the bundled
# PG share/ dir via a long .pnpm virtual-store path. On Windows that path exceeds
# MAX_PATH (260), so initdb fails with "postgresql.conf.sample does not exist".
# The hoisted linker flattens the platform binary to credit-core/node_modules/...
# (no .pnpm nesting), shortening the path below the limit.
node-linker=hoisted
